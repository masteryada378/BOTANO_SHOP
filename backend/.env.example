# Server Configuration
PORT=5005
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT Authentication
# JWT_SECRET — секретний ключ для підпису токенів. Ніколи не хардкодити.
# Кожне середовище (dev/staging/prod) має свій унікальний ключ.
JWT_SECRET=your_jwt_secret_change_me
# JWT_EXPIRES_IN — час життя access token. 7d достатньо для MVP.
JWT_EXPIRES_IN=7d